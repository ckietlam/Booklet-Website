<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome</title>
  <style>
    /* General Styles */
    body {
      font-family: 'Arial', sans-serif;
      margin: 0;
      padding: 0;
      background: linear-gradient(to right);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    /* Container Styles */
    .container {
      text-align: center;
      background: rgba(255, 255, 255, 0.1);
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
      max-width: 400px;
      width: 90%;
    }

    /* Heading Styles */
    h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
      color: #000000;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    p {
      font-size: 1.1rem;
      margin: 15px 0;
    }

    /* Button Styles */
    .button {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 20px;
      background: #ffdd00;
      color: #000;
      font-weight: bold;
      border-radius: 5px;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .button:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 10px rgba(0, 0, 0, 0.3);
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Welcome, <%= userName %>!</h1>
    <p>You have successfully signed in using Google.</p>
    <a href="/" class="button">Go to Homepage</a>
  </div>
</body>
</html>
